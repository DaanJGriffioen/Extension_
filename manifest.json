{
  "manifest_version": 3,
  "name": "Productivity Enhancer",
  "version": "1.0",
  "description": "Closes YouTube shorts, and reddit",
  "permissions": ["tabs", "activeTab", "cookies"],
  "background" : {
    "service_worker": "scripts/bg.js" 
  },
  "content_scripts": [ 
    {
      "matches": ["*://www.youtube.com/*", "*://*.reddit.com/*"],
      "js": ["scripts/content.js"]
    }
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.reddit.com/*"
  ],
  "action": {
    "default_title": "YouTube Auto Closer Active!"
  }
}